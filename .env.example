# --- Server only (set in Vercel Project → Settings → Environment Variables) ---
# OpenID token endpoint (full URL). Preferred over KEYCLOAK_ISSUER.
# e.g. https://auth.example.com/realms/my-realm/protocol/openid-connect/token
TOKEN_URL=

# Alternative: realm base URL (no trailing slash); token URL = issuer + /protocol/openid-connect/token
# KEYCLOAK_ISSUER=

KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=

# Optional: space-separated scopes if your client requires them
# KEYCLOAK_SCOPE=

# Upstream API base (no trailing slash). Only used by /api/demo when path is relative.
EXTERNAL_API_BASE_URL=

# Default path when opening /api/demo with no ?path= (e.g. /health or /v1/foo)
EXTERNAL_API_PATH=/

# Single full URL for offers (POST body from src/config/offers.ts). Only env used by GET /api/offers.
# If you see "/offers" in errors, another layer (e.g. Vercel env) is overriding — fix there or rely on .env on disk locally.
EXTERNAL_API_OFFERS_PATH=

# --- Public (exposed to the browser; never put secrets here) ---
# Optional label for the dummy UI
# NEXT_PUBLIC_APP_NAME=Demo
